<%- include('partials/header', { title: 'Tax Estimator', page: 'tax' }) %>

<div class="page-header">
  <div>
    <h1 class="page-title">Tax Estimator</h1>
    <p class="page-sub">Georgia · Married Filing Jointly · 2026 estimate</p>
  </div>
  <button class="btn btn-primary" id="btnSaveTax">Save & Recalculate</button>
</div>

<div id="saveMsg" class="save-toast" style="display:none">✓ Saved</div>

<!-- ── Tax Summary Cards ──────────────────────────────────── -->
<div class="stats-grid" id="taxSummary">
  <div class="stat-card">
    <div class="stat-label">Federal Income Tax</div>
    <div class="stat-value negative" id="taxFederal">—</div>
    <div class="stat-sub" id="taxFederalMo">—/mo</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Georgia State Tax</div>
    <div class="stat-value negative" id="taxState">—</div>
    <div class="stat-sub" id="taxStateMo">5.39% flat rate</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">FICA (SS + Medicare)</div>
    <div class="stat-value negative" id="taxFica">—</div>
    <div class="stat-sub" id="taxFicaMo">—/mo</div>
  </div>
  <div class="stat-card highlight">
    <div class="stat-label">Total Tax Burden</div>
    <div class="stat-value negative" id="taxTotal">—</div>
    <div class="stat-sub" id="taxEffective">Effective rate: —%</div>
  </div>
</div>

<div class="stats-grid" style="margin-top:-8px">
  <div class="stat-card">
    <div class="stat-label">Combined Gross Income</div>
    <div class="stat-value" id="txGross">—</div>
    <div class="stat-sub">Before tax & 401k</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Pre-tax 401k Deductions</div>
    <div class="stat-value positive" id="tx401k">—</div>
    <div class="stat-sub">Reduces taxable income</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Adjusted Gross Income</div>
    <div class="stat-value" id="txAGI">—</div>
    <div class="stat-sub">After 401k deductions</div>
  </div>
  <div class="stat-card highlight">
    <div class="stat-label">Monthly Take-Home</div>
    <div class="stat-value positive" id="txTakeHome">—</div>
    <div class="stat-sub">After all taxes</div>
  </div>
</div>

<!-- ── Tax Inputs ─────────────────────────────────────────── -->
<div class="charts-row" style="margin-top:4px">

  <div class="chart-card">
    <h3 class="chart-title">Income & Contributions</h3>
    <div style="display:flex;flex-direction:column;gap:14px;margin-top:4px">
      <div class="tax-person-block">
        <div class="tax-person-label" style="color:#059669">Ash</div>
        <div class="form-group">
          <label>Annual Gross Salary</label>
          <div class="input-wrap"><span>$</span><input type="number" id="ashGross" value="203000"></div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>401k Contribution %</label>
            <div class="input-wrap"><input type="number" id="ash401kPct" value="10" step="0.5"><span class="suffix">%</span></div>
          </div>
          <div class="form-group">
            <label>ROTH IRA % (post-tax)</label>
            <div class="input-wrap"><input type="number" id="ashRothPct" value="5" step="0.5"><span class="suffix">%</span></div>
          </div>
        </div>
      </div>
      <div class="tax-person-block">
        <div class="tax-person-label" style="color:#ec4899">KP</div>
        <div class="form-group">
          <label>Annual Gross Salary</label>
          <div class="input-wrap"><span>$</span><input type="number" id="kpGross" value="55000"></div>
        </div>
        <div class="form-group">
          <label>401k Contribution %</label>
          <div class="input-wrap"><input type="number" id="kp401kPct" value="7" step="0.5"><span class="suffix">%</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="chart-card">
    <h3 class="chart-title">Federal Tax Bracket Breakdown</h3>
    <div id="bracketTable"></div>
    <div class="tax-note" style="margin-top:12px">
      <strong>Standard Deduction (MFJ 2026):</strong> $30,000 federal · $24,000 Georgia<br>
      <strong>Georgia:</strong> 5.39% flat rate (2025+)<br>
      <strong>FICA:</strong> SS 6.2% (up to $176,100) + Medicare 1.45% + 0.9% surcharge above $200k
    </div>
  </div>

</div>

<!-- ── Monthly tax split for entry ───────────────────────── -->
<div class="chart-card fullwidth" style="margin-top:4px">
  <h3 class="chart-title">Monthly Tax Entry Guide</h3>
  <p class="chart-note">Use these numbers in the "Taxes" field of your Monthly Entry</p>
  <div class="tax-entry-grid" id="taxEntryGrid"></div>
</div>

<script>
const fmt = n => '$' + Math.round(n||0).toLocaleString();
const fmtD = n => '$' + (n||0).toLocaleString(undefined, {minimumFractionDigits:0, maximumFractionDigits:0});

async function loadTaxProfile() {
  const profile = await fetch('/api/profile').then(r => r.json());
  const tp = profile.taxProfile || {};
  if (tp.ashGross)   document.getElementById('ashGross').value   = tp.ashGross;
  if (tp.kpGross)    document.getElementById('kpGross').value    = tp.kpGross;
  if (tp.ash401kPct) document.getElementById('ash401kPct').value = tp.ash401kPct;
  if (tp.kp401kPct)  document.getElementById('kp401kPct').value  = tp.kp401kPct;
  if (tp.ashRothPct) document.getElementById('ashRothPct').value = tp.ashRothPct;
  recalc();
}

function recalc() {
  const ashGross   = parseFloat(document.getElementById('ashGross').value)   || 0;
  const kpGross    = parseFloat(document.getElementById('kpGross').value)    || 0;
  const ash401kPct = parseFloat(document.getElementById('ash401kPct').value) || 0;
  const kp401kPct  = parseFloat(document.getElementById('kp401kPct').value)  || 0;

  const ash401k = ashGross * ash401kPct / 100;
  const kp401k  = kpGross  * kp401kPct  / 100;
  const combined = ashGross + kpGross;
  const agi      = combined - ash401k - kp401k;

  // Federal
  const fedStd = 30000;
  const fedTaxable = Math.max(0, agi - fedStd);
  const brackets = [
    { limit: 23850,   rate: 0.10, label: '10%' },
    { limit: 96950,   rate: 0.12, label: '12%' },
    { limit: 206700,  rate: 0.22, label: '22%' },
    { limit: 394600,  rate: 0.24, label: '24%' },
    { limit: 501050,  rate: 0.32, label: '32%' },
    { limit: 751600,  rate: 0.35, label: '35%' },
    { limit: Infinity,rate: 0.37, label: '37%' }
  ];
  let federal = 0, prev = 0;
  const bracketRows = [];
  for (const b of brackets) {
    if (fedTaxable <= prev) break;
    const taxable = Math.min(fedTaxable, b.limit) - prev;
    const tax = taxable * b.rate;
    federal += tax;
    if (taxable > 0) bracketRows.push({ label: b.label, taxable: Math.round(taxable), tax: Math.round(tax) });
    prev = b.limit;
  }

  // Georgia
  const gaStd = 24000;
  const gaTaxable = Math.max(0, agi - gaStd);
  const state = gaTaxable * 0.0539;

  // FICA
  const ssCap = 176100;
  const ashSS    = Math.min(ashGross, ssCap) * 0.062;
  const kpSS     = Math.min(kpGross,  ssCap) * 0.062;
  const ashMed   = ashGross * 0.0145 + Math.max(0, ashGross - 200000) * 0.009;
  const kpMed    = kpGross  * 0.0145;
  const fica     = ashSS + kpSS + ashMed + kpMed;
  const total    = federal + state + fica;
  const effRate  = combined > 0 ? (total / combined * 100).toFixed(1) : 0;
  const takeHome = Math.round((combined - total) / 12);

  // Update summary cards
  document.getElementById('taxFederal').textContent  = fmt(federal);
  document.getElementById('taxFederalMo').textContent= fmt(federal/12) + '/mo';
  document.getElementById('taxState').textContent    = fmt(state);
  document.getElementById('taxStateMo').textContent  = fmt(state/12) + '/mo';
  document.getElementById('taxFica').textContent     = fmt(fica);
  document.getElementById('taxFicaMo').textContent   = fmt(fica/12) + '/mo';
  document.getElementById('taxTotal').textContent    = fmt(total);
  document.getElementById('taxEffective').textContent= `Effective rate: ${effRate}%`;
  document.getElementById('txGross').textContent     = fmt(combined);
  document.getElementById('tx401k').textContent      = fmt(ash401k + kp401k);
  document.getElementById('txAGI').textContent       = fmt(agi);
  document.getElementById('txTakeHome').textContent  = fmt(takeHome);

  // Bracket table
  document.getElementById('bracketTable').innerHTML = `
    <table class="breakdown-table">
      <thead><tr><th>Bracket</th><th>Income in bracket</th><th>Tax</th></tr></thead>
      <tbody>
        ${bracketRows.map(r => `<tr>
          <td>${r.label}</td>
          <td class="mono">${fmt(r.taxable)}</td>
          <td class="mono negative">${fmt(r.tax)}</td>
        </tr>`).join('')}
        <tr class="total-row">
          <td><strong>Total Federal</strong></td>
          <td></td>
          <td class="mono negative"><strong>${fmt(federal)}</strong></td>
        </tr>
      </tbody>
    </table>`;

  // Monthly entry guide
  const totalMo = Math.round(total / 12);
  document.getElementById('taxEntryGrid').innerHTML = `
    <div class="tax-entry-cards">
      <div class="tax-entry-card">
        <div class="tec-label">Enter in Monthly Entry → Taxes</div>
        <div class="tec-val negative">${fmt(totalMo)}/mo</div>
        <div class="tec-sub">Total estimated monthly tax</div>
      </div>
      <div class="tax-entry-card">
        <div class="tec-label">Breakdown</div>
        <div class="tec-rows">
          <div class="tec-row"><span>Federal Income Tax</span><span class="mono negative">-${fmt(Math.round(federal/12))}</span></div>
          <div class="tec-row"><span>Georgia State Tax</span><span class="mono negative">-${fmt(Math.round(state/12))}</span></div>
          <div class="tec-row"><span>FICA (SS + Medicare)</span><span class="mono negative">-${fmt(Math.round(fica/12))}</span></div>
          <div class="tec-row total"><span><strong>Total</strong></span><span class="mono negative"><strong>-${fmt(totalMo)}</strong></span></div>
        </div>
      </div>
      <div class="tax-entry-card">
        <div class="tec-label">Monthly Take-Home</div>
        <div class="tec-val positive">${fmt(takeHome)}</div>
        <div class="tec-sub">After all taxes (before expenses)</div>
      </div>
    </div>`;
}

document.querySelectorAll('input[type=number]').forEach(el => el.addEventListener('input', recalc));

document.getElementById('btnSaveTax').addEventListener('click', async () => {
  const btn = document.getElementById('btnSaveTax');
  btn.textContent = 'Saving...'; btn.disabled = true;
  try {
    const profile = await fetch('/api/profile').then(r => r.json());
    await fetch('/api/profile', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ...profile,
        taxProfile: {
          filingStatus: 'mfj',
          state: 'georgia',
          ashGross:   parseFloat(document.getElementById('ashGross').value)   || 203000,
          kpGross:    parseFloat(document.getElementById('kpGross').value)    || 55000,
          ash401kPct: parseFloat(document.getElementById('ash401kPct').value) || 10,
          kp401kPct:  parseFloat(document.getElementById('kp401kPct').value)  || 7,
          ashRothPct: parseFloat(document.getElementById('ashRothPct').value) || 5,
        }
      })
    });
    const toast = document.getElementById('saveMsg');
    toast.style.display = 'block';
    setTimeout(() => toast.style.display = 'none', 3000);
  } catch(e) { alert('Save failed: ' + e.message); }
  btn.textContent = 'Save & Recalculate'; btn.disabled = false;
});

loadTaxProfile();
</script>

<%- include('partials/footer') %>
