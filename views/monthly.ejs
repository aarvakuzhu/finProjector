<%- include('partials/header', { title: 'Monthly Entry', page: 'monthly' }) %>

<style>
/* ── Waterfall chart ─────────────────────────────── */
.waterfall-wrap { display: flex; flex-direction: column; gap: 0; }
.wf-row { display: grid; grid-template-columns: 160px 1fr 90px; align-items: center; gap: 10px; padding: 5px 0; border-bottom: 1px solid var(--border); }
.wf-row:last-child { border-bottom: none; }
.wf-label { font-size: 12px; color: var(--text-dim); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.wf-label.wf-total { font-family: 'Syne', sans-serif; font-weight: 700; color: var(--text); font-size: 13px; }
.wf-bar-wrap { position: relative; height: 20px; }
.wf-bar { position: absolute; top: 3px; height: 14px; border-radius: 3px; transition: width 0.4s ease; }
.wf-amount { font-family: 'JetBrains Mono', monospace; font-size: 12px; text-align: right; white-space: nowrap; }
.wf-section-header { grid-column: 1/-1; padding: 10px 0 2px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); }
.wf-divider { grid-column: 1/-1; border-top: 2px solid var(--border); margin: 4px 0; }
.source-tag { font-size: 10px; padding: 1px 5px; border-radius: 3px; margin-left: 4px; font-weight: 600; }
.tag-ash  { background: rgba(5,150,105,0.12); color: var(--accent); }
.tag-kp   { background: rgba(236,72,153,0.12); color: #ec4899; }
.tag-both { background: rgba(99,102,241,0.12); color: var(--accent2); }
.tag-inv  { background: rgba(245,158,11,0.12); color: var(--warning); }

/* ── Split view ──────────────────────────────────── */
.monthly-layout { display: grid; grid-template-columns: 1fr 420px; gap: 20px; align-items: start; }
@media (max-width: 1100px) { .monthly-layout { grid-template-columns: 1fr; } }
</style>

<div class="page-header">
  <div>
    <h1 class="page-title">Monthly Entry</h1>
    <p class="page-sub">Record income, expenses and investments</p>
  </div>
  <div class="header-actions">
    <button class="btn btn-ghost" id="btnFillEstimates">📋 Fill Estimates</button>
    <button class="btn btn-primary" id="btnSave">Save Entry</button>
    <button class="btn btn-danger" id="btnDelete" style="display:none">Delete</button>
  </div>
</div>

<div class="month-selector-row">
  <div class="month-nav">
    <button class="btn btn-ghost" id="btnPrev">← Prev</button>
    <div class="month-display" id="monthDisplay">Loading...</div>
    <button class="btn btn-ghost" id="btnNext">Next →</button>
  </div>
  <div class="month-actions">
    <span class="entry-status" id="entryStatus"></span>
  </div>
</div>

<div class="monthly-layout">

  <!-- LEFT: Entry form -->
  <div style="display:flex;flex-direction:column;gap:18px">

    <!-- INCOME -->
    <div class="entry-section">
      <div class="section-header income-header">
        <svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
        Income
        <span class="section-total" id="totalIncome">$0</span>
      </div>
      <div class="fields-grid">
        <div class="field-row"><label>Ash Salary</label><div class="input-wrap"><span>$</span><input type="number" id="income_salary" placeholder="16917"></div></div>
        <div class="field-row"><label>KP Salary</label><div class="input-wrap"><span>$</span><input type="number" id="income_other" placeholder="4583"></div></div>
        <div class="field-row"><label>Bonus</label><div class="input-wrap"><span>$</span><input type="number" id="income_bonus" placeholder="0"></div></div>
        <div class="field-row"><label>Rental Income</label><div class="input-wrap"><span>$</span><input type="number" id="income_rental" placeholder="2350"></div></div>
        <div class="field-row"><label>Investment Returns</label><div class="input-wrap"><span>$</span><input type="number" id="income_investments" placeholder="0"></div></div>
      </div>
    </div>

    <!-- EXPENSES -->
    <div class="entry-section">
      <div class="section-header expense-header">
        <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg>
        Expenses
        <span class="section-total" id="totalExpenses">$0</span>
      </div>
      <div class="fields-grid">
        <!-- Tax row -->
        <div class="field-row" style="grid-column:1/-1">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <label style="flex-shrink:0">Taxes <span class="tax-auto-badge" id="taxBadge">Auto</span></label>
            <div style="display:flex;gap:8px;font-size:11px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;flex-wrap:wrap">
              <span id="taxBreakFed">Fed —</span>
              <span id="taxBreakState">GA —</span>
              <span id="taxBreakFica">FICA —</span>
              <button class="btn-recalc" id="btnRecalcTax">↺ Reset</button>
            </div>
          </div>
          <div class="input-wrap" style="max-width:200px"><span>$</span><input type="number" id="expenses_taxes" placeholder="5340"></div>
        </div>
        <div class="field-row"><label>Housing / Mortgage</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_housing" placeholder="3150"></div></div>
        <div class="field-row"><label>Utilities <span class="yearly-hint">Sawnee $207 · Xoom $111 · AT&T $95 · Water $73</span></label><div class="input-wrap"><span>$</span><input type="number" id="expenses_utilities" placeholder="486.34"></div></div>
        <div class="field-row"><label>Groceries</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_groceries" placeholder="1200"></div></div>
        <div class="field-row"><label>Dining Out</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_dining" placeholder="400"></div></div>
        <div class="field-row"><label>Transport / Gas</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_transport" placeholder="350"></div></div>
        <div class="field-row"><label>Insurance</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_insurance" placeholder="650"></div></div>
        <div class="field-row"><label>Healthcare</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_healthcare" placeholder="850"></div></div>
        <div class="field-row"><label>Kids Classes <span class="yearly-hint">2 × $120/mo</span></label><div class="input-wrap"><span>$</span><input type="number" id="expenses_childcare" placeholder="240"></div></div>
        <div class="field-row"><label>Subscriptions + Phone <span class="yearly-hint">Netflix $15 · Prime $13 · Gym $80 · Phone $180 · Print $10 · Costco $5 · BJs $2</span></label><div class="input-wrap"><span>$</span><input type="number" id="expenses_subscriptions" placeholder="305.42"></div></div>
        <div class="field-row"><label>Clothing <span class="yearly-hint">$2,400/yr</span></label><div class="input-wrap"><span>$</span><input type="number" id="expenses_clothing" placeholder="200"></div></div>
        <div class="field-row"><label>Entertainment</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_entertainment" placeholder="200"></div></div>
        <div class="field-row"><label>Travel <span class="yearly-hint">$10,000/yr</span></label><div class="input-wrap"><span>$</span><input type="number" id="expenses_travel" placeholder="833"></div></div>
        <div class="field-row"><label>Gifts <span class="yearly-hint">$3,000/yr</span></label><div class="input-wrap"><span>$</span><input type="number" id="expenses_education" placeholder="250"></div></div>
        <div class="field-row"><label>Other</label><div class="input-wrap"><span>$</span><input type="number" id="expenses_other" placeholder="250"></div></div>
      </div>
    </div>

    <!-- INVESTMENTS -->
    <div class="entry-section">
      <div class="section-header invest-header">
        <svg viewBox="0 0 24 24"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/></svg>
        Investments
        <span class="section-total" id="totalInvested">$0</span>
      </div>
      <div class="fields-grid">
        <div class="field-row"><label>401k — Ash + KP</label><div class="input-wrap"><span>$</span><input type="number" id="investments_retirement401k" placeholder="2013"></div></div>
        <div class="field-row"><label>ROTH IRA — Ash</label><div class="input-wrap"><span>$</span><input type="number" id="investments_ira" placeholder="846"></div></div>
        <div class="field-row"><label>Brokerage</label><div class="input-wrap"><span>$</span><input type="number" id="investments_brokerage" placeholder="0"></div></div>
        <div class="field-row"><label>Savings Transfer</label><div class="input-wrap"><span>$</span><input type="number" id="investments_savings" placeholder="0"></div></div>
        <div class="field-row"><label>HSA</label><div class="input-wrap"><span>$</span><input type="number" id="investments_hsa" placeholder="150"></div></div>
        <div class="field-row"><label>Other</label><div class="input-wrap"><span>$</span><input type="number" id="investments_other" placeholder="0"></div></div>
      </div>
    </div>

    <!-- Notes -->
    <div class="entry-section">
      <div class="notes-row" style="padding:16px">
        <label>Notes</label>
        <textarea id="notes" placeholder="Any notes for this month..."></textarea>
      </div>
    </div>

  </div>

  <!-- RIGHT: Cash flow waterfall -->
  <div style="position:sticky;top:20px;display:flex;flex-direction:column;gap:16px">

    <div class="chart-card">
      <h3 class="chart-title">Cash Flow Waterfall</h3>
      <p class="chart-note">How income flows through expenses to savings</p>
      <div class="waterfall-wrap" id="waterfall"></div>
    </div>


  </div>

</div>

<script>
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const now = new Date();
let currentYear = now.getFullYear();
let currentMonth = now.getMonth() + 1;
let calculatedTax = 5340;
let taxManuallyChanged = false;
let rentalSummary = null;

const ESTIMATES = {
  income: { salary: 16917, other: 4583, bonus: 0, rental: 2350, investments: 0 },
  expenses: { taxes: null, housing: 3150, utilities: 486.34, groceries: 1200, dining: 400,
    transport: 350, insurance: 650, healthcare: 850, childcare: 240, subscriptions: 305.42,
    clothing: 200, entertainment: 200, travel: 833, education: 250, other: 250 },
  investments: { retirement401k: 2013, ira: 846, brokerage: 0, savings: 0, hsa: 150, other: 0 }
};

const fmt  = n => '$' + Math.abs(Math.round(n||0)).toLocaleString();
const fmtS = n => (n>=0?'+':'-') + '$' + Math.abs(Math.round(n||0)).toLocaleString();
const getV = id => parseFloat(document.getElementById(id)?.value) || 0;

function updateDisplay() {
  document.getElementById('monthDisplay').textContent = `${MONTHS[currentMonth-1]} ${currentYear}`;
  loadEntry();
}

// ── Waterfall ────────────────────────────────────────────
function buildWaterfall() {
  const ashSalary  = getV('income_salary');
  const kpSalary   = getV('income_other');
  const bonus      = getV('income_bonus');
  const rental     = getV('income_rental');
  const invIncome  = getV('income_investments');

  const taxes      = getV('expenses_taxes');
  const housing    = getV('expenses_housing');
  const utilities  = getV('expenses_utilities');
  const groceries  = getV('expenses_groceries');
  const dining     = getV('expenses_dining');
  const transport  = getV('expenses_transport');
  const insurance  = getV('expenses_insurance');
  const healthcare = getV('expenses_healthcare');
  const kids       = getV('expenses_childcare');
  const subs       = getV('expenses_subscriptions');
  const clothing   = getV('expenses_clothing');
  const entertain  = getV('expenses_entertainment');
  const travel     = getV('expenses_travel');
  const gifts      = getV('expenses_education');
  const other      = getV('expenses_other');

  const inv401k    = getV('investments_retirement401k');
  const invIra     = getV('investments_ira');
  const invBrok    = getV('investments_brokerage');
  const invSav     = getV('investments_savings');
  const invHsa     = getV('investments_hsa');
  const invOther   = getV('investments_other');
  const totalInv   = inv401k + invIra + invBrok + invSav + invHsa + invOther;

  const totalExp   = taxes + housing + utilities + groceries + dining + transport +
                     insurance + healthcare + kids + subs + clothing + entertain + travel + gifts + other;
  const totalIncome = ashSalary + kpSalary + bonus + rental + invIncome;

  // Update header totals
  document.getElementById('totalIncome').textContent   = fmt(totalIncome);
  document.getElementById('totalExpenses').textContent = fmt(totalExp);
  document.getElementById('totalInvested').textContent = fmt(totalInv);

  // ── Income layers: Ash → KP → Rental → Other
  // All expenses charged to Ash first; KP covers overflow; Rental covers remainder
  const allExpAndInv = totalExp + totalInv;
  const ashBalance  = ashSalary + bonus - allExpAndInv;  // can go negative
  const kpBalance   = ashBalance < 0 ? kpSalary + ashBalance : kpSalary; // KP absorbs deficit if Ash negative
  const rentalBalance = kpBalance < 0 ? rental + kpBalance : rental;     // Rental absorbs if still negative
  const netFinal    = (ashBalance < 0 ? 0 : ashBalance) +
                      (kpBalance < 0 ? 0 : kpBalance) +
                      (rentalBalance < 0 ? 0 : rentalBalance) +
                      (kpBalance >= 0 && rentalBalance >= 0 ? 0 : 0);
  // Simpler: just total income minus all outflows
  const netSurplus  = totalIncome - totalExp - totalInv;

  const maxVal = Math.max(totalIncome, 1);

  // Expense line items grouped in order
  const expenseItems = [
    // Fixed — Ash pays these first
    { label: 'Taxes',         amount: taxes,      color: '#dc2626', group: 'Fixed Costs' },
    { label: 'Mortgage',      amount: housing,    color: '#ef4444', group: 'Fixed Costs' },
    { label: 'Insurance',     amount: insurance,  color: '#f87171', group: 'Fixed Costs' },
    { label: 'Healthcare',    amount: healthcare, color: '#fb923c', group: 'Fixed Costs' },
    // Household
    { label: 'Utilities',     amount: utilities,  color: '#f97316', group: 'Household' },
    { label: 'Groceries',     amount: groceries,  color: '#f59e0b', group: 'Household' },
    { label: 'Transport',     amount: transport,  color: '#eab308', group: 'Household' },
    { label: 'Subscriptions', amount: subs,       color: '#84cc16', group: 'Household' },
    // Lifestyle
    { label: 'Dining',        amount: dining,     color: '#06b6d4', group: 'Lifestyle' },
    { label: 'Kids',          amount: kids,       color: '#0ea5e9', group: 'Lifestyle' },
    { label: 'Clothing',      amount: clothing,   color: '#6366f1', group: 'Lifestyle' },
    { label: 'Entertainment', amount: entertain,  color: '#8b5cf6', group: 'Lifestyle' },
    // Discretionary
    { label: 'Travel',        amount: travel,     color: '#a855f7', group: 'Discretionary' },
    { label: 'Gifts',         amount: gifts,      color: '#ec4899', group: 'Discretionary' },
    { label: 'Other',         amount: other,      color: '#94a3b8', group: 'Discretionary' },
  ].filter(e => e.amount > 0);

  const invItems = [
    { label: '401k (Ash+KP)', amount: inv401k, color: '#059669' },
    { label: 'ROTH IRA',      amount: invIra,  color: '#10b981' },
    { label: 'Brokerage',     amount: invBrok, color: '#34d399' },
    { label: 'Savings',       amount: invSav,  color: '#6ee7b7' },
    { label: 'HSA',           amount: invHsa,  color: '#a7f3d0' },
    { label: 'Other Invest',  amount: invOther,color: '#d1fae5' },
  ].filter(e => e.amount > 0);

  // ── Investment deduction split ──────────────────────────────
  // Ash pays: his 401k ($1,692) + ROTH IRA ($846) — deducted from Ash salary
  // KP pays:  her 401k ($321)                     — deducted from KP salary
  // The investments field stores combined 401k (Ash+KP = $2,013)
  // We split: KP portion = $321, Ash portion = remainder
  const KP_401K = 321;                          // KP's 401k contribution
  const ash401k_ded = Math.max(0, inv401k - KP_401K); // Ash's 401k only
  const kp401k_ded  = Math.min(inv401k, KP_401K);     // KP's 401k only
  const ashRoth_ded = invIra;                   // ROTH — Ash only, post-tax payroll

  const discInvItems = [
    { label: 'Brokerage',    amount: invBrok,  color: '#34d399' },
    { label: 'Savings',      amount: invSav,   color: '#6ee7b7' },
    { label: 'HSA',          amount: invHsa,   color: '#a7f3d0' },
    { label: 'Other Invest', amount: invOther, color: '#d1fae5' },
  ].filter(e => e.amount > 0);

  let running = 0;
  let wentNegativeOnAsh = false;

  const barW = n => Math.min(100, Math.abs(n) / maxVal * 100).toFixed(1);
  const fmtR = n => `<span class="${n>=0?'positive':'negative'}" style="font-weight:700">${fmtS(n)}</span>`;

  let html = '';

  // ── STEP 1: ASH SALARY ───────────────────────────────────
  html += row('header', '💼 Ash Gross Income', '', '', 'tag-ash');
  if (ashSalary) { running += ashSalary; html += incRow('Ash Salary', ashSalary, '#059669', running, maxVal); }
  if (bonus)     { running += bonus;     html += incRow('Bonus',      bonus,      '#10b981', running, maxVal); }

  // ── STEP 2: DEDUCT 401k + ROTH FROM SALARY ──────────────
  // These are payroll deductions — never available for spending
  const dedItems = [
    { label: '401k — Ash only', amount: ash401k_ded, color: '#0d9488' },
    { label: 'ROTH IRA — Ash',  amount: ashRoth_ded, color: '#14b8a6' },
  ].filter(e => e.amount > 0);

  if (dedItems.length) {
    html += row('header', '✂️ Ash Payroll Deductions', '', '', 'tag-ash');
    dedItems.forEach(e => {
      running -= e.amount;
      html += expRow(e.label, e.amount, e.color, running, maxVal, '', 'inv');
    });
    html += subtotalRow('Ash Take-Home', running);
  }

  // ── STEP 3: ALL EXPENSES charged to Ash take-home ────────
  const groups = ['Fixed Costs','Household','Lifestyle','Discretionary'];
  groups.forEach(g => {
    const items = expenseItems.filter(e => e.group === g);
    if (!items.length) return;
    html += row('header', `📌 ${g}`, '', '', '');
    items.forEach(e => {
      running -= e.amount;
      if (running < 0 && !wentNegativeOnAsh) {
        wentNegativeOnAsh = true;
      }
      const overTag = running < 0 ? ' <span class="source-tag" style="background:rgba(236,72,153,0.15);color:#ec4899">→ KP covers</span>' : '';
      html += expRow(e.label, e.amount, e.color, running, maxVal, overTag);
    });
    html += subtotalRow(`After ${g}`, running);
  });

  // ── STEP 4: KP SALARY covers deficit or adds to surplus ──
  html += row('divider', '', '', '', '');
  const labelKP = running < 0 ? '👩 KP Salary — covers shortfall' : '👩 KP Salary — adds to surplus';
  html += row('header', labelKP, '', '', 'tag-kp');
  html += incRow('KP Salary', kpSalary, '#ec4899', running, maxVal);
  running += kpSalary;
  if (kp401k_ded > 0) {
    html += expRow('401k — KP', kp401k_ded, '#0d9488', running - kp401k_ded, maxVal, '', 'inv');
    running -= kp401k_ded;
  }
  html += subtotalRow('KP Take-Home', running);

  // ── STEP 5: RENTAL — expenses first, then net flows in ────
  html += row('divider', '', '', '', '');
  if (rental > 0) {
    html += row('header', '🏠 Rental Property — Net Cash Flow', '', '', 'tag-inv');
    html += incRow('Gross Rent', rental, '#6366f1', running, maxVal);

    // Pull expense lines from saved rental data or use known defaults
    let rentalExpLines = [];
    if (rentalSummary && rentalSummary.properties && rentalSummary.properties.length > 0) {
      const rd = rentalSummary.properties[0].expenseDetail;
      rentalExpLines = [
        { label: 'Mortgage + Escrow', amount: rd.mortgage },
        { label: 'HOA',               amount: rd.hoa },
        { label: 'Rental Fee',        amount: rd.rentalFee },
        { label: 'Trugreen',          amount: rd.trugreen },
        { label: 'Termite',           amount: rd.termite },
        { label: 'Mowing',            amount: rd.mowing },
        { label: 'Maintenance',       amount: rd.maintenance },
        { label: 'Other',             amount: rd.other || 0 },
        ...(rd.multiYear || []).map(e => ({ label: e.name, amount: e.monthly }))
      ].filter(e => e.amount > 0.01);
    } else {
      // Known defaults — matches rental page pre-fill
      rentalExpLines = [
        { label: 'Mortgage + Escrow', amount: 2160.98 },
        { label: 'HOA',               amount: 500/12 },
        { label: 'Rental Fee',        amount: 300/12 },
        { label: 'Trugreen',          amount: 300/12 },
        { label: 'Termite',           amount: 200/12 },
        { label: 'Mowing',            amount: 630/12 },
        { label: 'Maintenance',       amount: 3000/12 },
        { label: 'Home Warranty',     amount: 2100/5/12 },
      ].filter(e => e.amount > 0.01);
    }

    let rentalRunning = rental;
    rentalExpLines.forEach(e => {
      rentalRunning -= e.amount;
      html += expRow(e.label, e.amount, '#818cf8', rentalRunning, maxVal, '', 'rental');
    });

    const rentalNet = rentalRunning;  // net after all rental expenses
    running += rentalNet;             // only net flows into main running total
    html += subtotalRow(
      rentalNet >= 0 ? 'Rental surplus → salary' : 'Rental deficit ← salary covers',
      running
    );
  }

  // ── STEP 6: Discretionary investments (post-expense) ──────
  if (discInvItems.length) {
    html += row('divider', '', '', '', '');
    html += row('header', '📈 Additional Investments', '', '', '');
    discInvItems.forEach(e => {
      running -= e.amount;
      html += expRow(e.label, e.amount, e.color, running, maxVal, '', 'inv');
    });
    html += subtotalRow('After Additional Investments', running);
  }

  // ── FINAL NET ────────────────────────────────────────────
  html += row('divider', '', '', '', '');
  html += `<div class="wf-row wf-net-row">
    <div class="wf-label wf-total">💵 Monthly Net Cash Saved</div>
    <div class="wf-bar-wrap">
      <div class="wf-bar" style="width:${barW(running)}%;background:${running>=0?'var(--accent)':'var(--danger)'}"></div>
    </div>
    <div class="wf-amount" style="font-size:15px">${fmtR(running)}</div>
  </div>`;

  document.getElementById('waterfall').innerHTML = html;
}

function row(type, label, barHtml, amount, tagClass) {
  if (type === 'header') return `<div class="wf-row"><div class="wf-section-header">${label} ${tagClass ? `<span class="source-tag ${tagClass}">${tagClass==='tag-ash'?'Ash':tagClass==='tag-kp'?'KP':tagClass==='tag-inv'?'Rental/Invest':''}</span>`:''}</div></div>`;
  if (type === 'divider') return `<div class="wf-row"><div class="wf-divider"></div></div>`;
  return '';
}

function incRow(label, amount, color, running, maxVal) {
  const pct = Math.min(100, amount / maxVal * 100).toFixed(1);
  return `<div class="wf-row">
    <div class="wf-label">${label}</div>
    <div class="wf-bar-wrap"><div class="wf-bar" style="width:${pct}%;background:${color};opacity:0.8"></div></div>
    <div class="wf-amount positive">+${fmt(amount)}</div>
  </div>`;
}

function expRow(label, amount, color, running, maxVal, extra='', type='') {
  const pct = Math.min(100, amount / maxVal * 100).toFixed(1);
  const amtColor = type === 'inv' ? 'color:var(--warning)' : type === 'rental' ? 'color:#818cf8' : 'color:var(--danger)';
  return `<div class="wf-row">
    <div class="wf-label">${label}${extra}</div>
    <div class="wf-bar-wrap"><div class="wf-bar" style="width:${pct}%;background:${color};opacity:0.7"></div></div>
    <div class="wf-amount" style="${amtColor}">-${fmt(amount)}</div>
  </div>`;
}

function subtotalRow(label, running) {
  const pct = Math.min(100, Math.abs(running) / 23850 * 100).toFixed(1);
  return `<div class="wf-row wf-subtotal">
    <div class="wf-label wf-total">${label}</div>
    <div class="wf-bar-wrap">
      ${running >= 0
        ? `<div class="wf-bar" style="width:${pct}%;background:var(--accent);opacity:0.35"></div>`
        : `<div class="wf-bar" style="width:${pct}%;background:var(--danger);opacity:0.35;right:0;position:absolute"></div>`}
    </div>
    <div class="wf-amount ${running>=0?'positive':'negative'}" style="font-weight:700">${fmtS(running)}</div>
  </div>`;
}

// ── Tax auto-load ────────────────────────────────────────
async function loadTax() {
  try {
    const tax = await fetch('/api/tax').then(r => r.json());
    if (tax?.monthly) {
      calculatedTax = tax.monthly.total;
      document.getElementById('taxBreakFed').textContent   = `Fed $${tax.monthly.federal.toLocaleString()}`;
      document.getElementById('taxBreakState').textContent = `GA $${tax.monthly.state.toLocaleString()}`;
      document.getElementById('taxBreakFica').textContent  = `FICA $${tax.monthly.fica.toLocaleString()}`;
      ESTIMATES.expenses.taxes = calculatedTax;
      const tf = document.getElementById('expenses_taxes');
      if (!tf.value || !taxManuallyChanged) { tf.value = calculatedTax; taxManuallyChanged = false; }
      buildWaterfall();
    }
  } catch(e) { console.error('Tax load error:', e); }
}

// ── Load Rental P&L ─────────────────────────────────────
async function loadRental() {
  try {
    const data = await fetch('/api/rental-summary').then(r => r.json());
    if (data && data.totals) rentalSummary = data;
  } catch(e) { console.error('Rental load error:', e); }
}

document.getElementById('btnRecalcTax').addEventListener('click', () => {
  document.getElementById('expenses_taxes').value = calculatedTax;
  document.getElementById('taxBadge').textContent = 'Auto';
  document.getElementById('taxBadge').className = 'tax-auto-badge';
  taxManuallyChanged = false;
  buildWaterfall();
});

document.getElementById('expenses_taxes').addEventListener('input', () => {
  const v = parseFloat(document.getElementById('expenses_taxes').value) || 0;
  taxManuallyChanged = v !== calculatedTax;
  document.getElementById('taxBadge').textContent = taxManuallyChanged ? 'Manual' : 'Auto';
  document.getElementById('taxBadge').className   = 'tax-auto-badge' + (taxManuallyChanged ? ' manual' : '');
  buildWaterfall();
});

// ── Fill estimates ───────────────────────────────────────
document.getElementById('btnFillEstimates').addEventListener('click', () => {
  if (!confirm('Fill empty fields with Cumming GA estimates?')) return;
  const fill = (id, val) => { const el = document.getElementById(id); if (el && (!el.value || +el.value === 0)) el.value = val || ''; };
  Object.entries(ESTIMATES.income).forEach(([k,v]) => fill(`income_${k}`, v));
  Object.entries(ESTIMATES.expenses).forEach(([k,v]) => {
    if (k === 'taxes') fill('expenses_taxes', calculatedTax);
    else fill(`expenses_${k}`, v);
  });
  Object.entries(ESTIMATES.investments).forEach(([k,v]) => fill(`investments_${k}`, v));
  buildWaterfall();
});

// ── Load entry ───────────────────────────────────────────
async function loadEntry() {
  const data = await fetch(`/api/entries/${currentYear}/${currentMonth}`).then(r => r.json());
  const statusEl = document.getElementById('entryStatus');
  document.querySelectorAll('input[type=number]').forEach(el => el.value = '');
  document.getElementById('notes').value = '';
  taxManuallyChanged = false;

  if (data?._id) {
    statusEl.textContent = '✓ Saved'; statusEl.className = 'entry-status saved';
    document.getElementById('btnDelete').style.display = '';
    ['salary','bonus','rental','investments','other'].forEach(k => {
      const el = document.getElementById(`income_${k}`);
      if (el && data.income) el.value = data.income[k] || '';
    });
    ['housing','utilities','groceries','dining','transport','insurance','healthcare',
     'education','entertainment','clothing','travel','subscriptions','childcare','taxes','other'].forEach(k => {
      const el = document.getElementById(`expenses_${k}`);
      if (el && data.expenses) el.value = data.expenses[k] || '';
    });
    ['retirement401k','ira','brokerage','savings','hsa','other'].forEach(k => {
      const el = document.getElementById(`investments_${k}`);
      if (el && data.investments) el.value = data.investments[k] || '';
    });
    document.getElementById('notes').value = data.notes || '';
    const savedTax = data.expenses?.taxes || 0;
    if (savedTax && savedTax !== calculatedTax) {
      taxManuallyChanged = true;
      document.getElementById('taxBadge').textContent = 'Manual';
      document.getElementById('taxBadge').className = 'tax-auto-badge manual';
    }
  } else {
    statusEl.textContent = '○ Not entered'; statusEl.className = 'entry-status empty';
    document.getElementById('btnDelete').style.display = 'none';
    document.getElementById('expenses_taxes').value = calculatedTax;
  }
  buildWaterfall();
}

document.getElementById('btnPrev').addEventListener('click', () => {
  currentMonth--; if (currentMonth < 1) { currentMonth = 12; currentYear--; } updateDisplay();
});
document.getElementById('btnNext').addEventListener('click', () => {
  currentMonth++; if (currentMonth > 12) { currentMonth = 1; currentYear++; } updateDisplay();
});

document.querySelectorAll('input[type=number]').forEach(el => {
  if (el.id !== 'expenses_taxes') el.addEventListener('input', buildWaterfall);
});

document.getElementById('btnSave').addEventListener('click', async () => {
  const getE = k => getV(`expenses_${k}`);
  const getI = k => getV(`investments_${k}`);
  const body = {
    income: { salary:getV('income_salary'), bonus:getV('income_bonus'), rental:getV('income_rental'), investments:getV('income_investments'), other:getV('income_other') },
    expenses: { housing:getE('housing'), utilities:getE('utilities'), groceries:getE('groceries'), dining:getE('dining'), transport:getE('transport'), insurance:getE('insurance'), healthcare:getE('healthcare'), education:getE('education'), entertainment:getE('entertainment'), clothing:getE('clothing'), travel:getE('travel'), subscriptions:getE('subscriptions'), childcare:getE('childcare'), taxes:getE('taxes'), other:getE('other') },
    investments: { retirement401k:getI('retirement401k'), ira:getI('ira'), brokerage:getI('brokerage'), savings:getI('savings'), hsa:getI('hsa'), other:getI('other') },
    notes: document.getElementById('notes').value
  };
  const btn = document.getElementById('btnSave');
  btn.textContent = 'Saving...'; btn.disabled = true;
  await fetch(`/api/entries/${currentYear}/${currentMonth}`, {
    method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body)
  });
  btn.textContent = 'Save Entry'; btn.disabled = false;
  loadEntry();
});

document.getElementById('btnDelete').addEventListener('click', async () => {
  if (!confirm('Delete this month\'s entry?')) return;
  await fetch(`/api/entries/${currentYear}/${currentMonth}`, { method:'DELETE' });
  loadEntry();
});

Promise.all([loadTax(), loadRental()]).then(() => updateDisplay());
</script>

